# Copy this file to .env.local and fill in your Supabase project credentials
# Found at: https://app.supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Newer Supabase projects use PUBLISHABLE_KEY, older ones use ANON_KEY — either works
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY_HERE
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
